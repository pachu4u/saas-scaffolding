{
  "realm": "saas-platform",
  "enabled": true,
  "displayName": "SaaS Platform",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "accessTokenLifespan": 300,
  "accessTokenLifespanForImplicitFlow": 900,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "roles": {
    "realm": [
      {
        "name": "platform_super_admin",
        "description": "Full platform access"
      },
      {
        "name": "platform_support",
        "description": "Read-only platform support access"
      }
    ]
  },
  "groups": [
    {
      "name": "acme",
      "attributes": {
        "tenant_slug": ["acme"]
      }
    },
    {
      "name": "globex",
      "attributes": {
        "tenant_slug": ["globex"]
      }
    },
    {
      "name": "platform_super_admin"
    },
    {
      "name": "platform_support"
    }
  ],
  "clients": [
    {
      "clientId": "web",
      "name": "SaaS Platform Web",
      "enabled": true,
      "publicClient": false,
      "secret": "saas-scaffolding-keycloak-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "https://app.lvh.me/*",
        "https://*.lvh.me/*",
        "http://localhost:3000/*",
        "https://saas.techhanker.com/*",
        "https://*.techhanker.com/*",
        "https://acme.techhanker.com/*",
        "https://demo.techhanker.com/*",
        "https://test.techhanker.com/*"
      ],
      "webOrigins": [
        "https://app.lvh.me",
        "https://*.lvh.me",
        "http://localhost:3000",
        "https://saas.techhanker.com",
        "https://*.techhanker.com",
        "https://acme.techhanker.com",
        "https://demo.techhanker.com",
        "https://test.techhanker.com"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "access.token.lifespan": "300",
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "https://saas.techhanker.com/auth/signin##https://saas.techhanker.com/*##https://*.techhanker.com/*##https://app.lvh.me/*##https://*.lvh.me/*##http://localhost:3000/*##https://acme.techhanker.com/auth/signin##https://acme.techhanker.com/*##https://demo.techhanker.com/auth/signin##https://demo.techhanker.com/*##https://test.techhanker.com/auth/signin##https://test.techhanker.com/*"
      },
      "protocolMappers": [
        {
          "name": "tenant_ids",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        },
        {
          "name": "audience",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "consentRequired": false,
          "config": {
            "included.client.audience": "web",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        },
        {
          "name": "saas_plan",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "saas_plan",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "saas_plan",
            "jsonType.label": "String"
          }
        },
        {
          "name": "saas_role",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "saas_role",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "saas_role",
            "jsonType.label": "String"
          }
        },
        {
          "name": "saas_tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "saas_tenant_id",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "saas_tenant_id",
            "jsonType.label": "String"
          }
        },
        {
          "name": "usage_locked",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "usage_locked",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "usage_locked",
            "jsonType.label": "boolean"
          }
        }
      ]
    },
    {
      "clientId": "oauth2-proxy",
      "name": "Tenant Subdomain Auth Gate (oauth2-proxy)",
      "enabled": true,
      "publicClient": false,
      "secret": "517ff84882c2ab974e5828605b800d209836634eec6afde5",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "protocol": "openid-connect",
      "redirectUris": ["https://oauthproxy.techhanker.com/oauth2/callback"],
      "webOrigins": ["https://oauthproxy.techhanker.com"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "https://oauthproxy.techhanker.com/*"
      },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "consentRequired": false,
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "groups",
            "jsonType.label": "String",
            "multivalued": "true"
          }
        }
      ]
    },
    {
      "clientId": "platform-admin-cli",
      "name": "Platform Admin CLI",
      "enabled": true,
      "publicClient": false,
      "secret": "change-me-admin-cli-secret",
      "serviceAccountsEnabled": true,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "protocol": "openid-connect"
    }
  ],
