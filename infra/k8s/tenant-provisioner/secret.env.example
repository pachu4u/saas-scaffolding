# Template for the saas-workers-env Secret consumed by deployment.yaml
# (envFrom -> secretRef). Copy to secret.env (gitignored) alongside this
# file, fill in real values, then run ./deploy.sh — it creates/updates the
# Secret via `kubectl create secret generic ... --from-env-file` and never
# writes real values into a tracked manifest.
#
# Most of these mirror the same variables the docker-compose `workers`
# service reads from the repo-root .env — see docs/infra/tenant-provisioner.md.

NODE_ENV=production
PORT=3000

DATABASE_URL=
DATABASE_URL_MIGRATOR=
REDIS_URL=

AUTH_SECRET=
AUTH_URL=

KEYCLOAK_ADMIN=
KEYCLOAK_ADMIN_USERNAME=
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_CLIENT_ID=
KEYCLOAK_CLIENT_SECRET=
KEYCLOAK_REALM=
KEYCLOAK_ISSUER=
KEYCLOAK_INTERNAL_ISSUER=
KEYCLOAK_INTERNAL_URL=

# This is the setting that makes this deployment the real tenant
# provisioner instead of a dead-code path — see docs/infra/tenant-provisioner.md
TENANT_STACK_DRIVER=kubernetes
TENANT_BASE_DOMAIN=
TENANT_INGRESS_CLASS=
TENANT_PG_ADMIN_URL=
TENANT_POD_CPU_LIMIT=
TENANT_POD_MEMORY_LIMIT=

RIOGENTIX_IMAGE=
RIOGENTIX_CONTAINER_PORT=
RIOGENTIX_INTERNAL_URL=
RIOGENTIX_PUBLIC_URL=
RIOGENTIX_INTERNAL_SECRET=
RIOGENTIX_SAAS_INTERNAL_SECRET=
PLATFORM_INTERNAL_SECRET=

NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

EMAIL_FROM=
RESEND_API_KEY=

OTEL_SERVICE_NAME=saas-workers
OTEL_EXPORTER_OTLP_ENDPOINT=

VAULT_ADDR=
VAULT_MOUNT_PATH=
VAULT_TOKEN=
