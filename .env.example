# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://app.lvh.me
PORT=3000

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://app:app_secret@localhost:5432/saas_platform
DATABASE_URL_MIGRATOR=postgresql://migrator:migrator_secret@localhost:5432/saas_platform

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ISSUER=https://auth.lvh.me/realms/saas-platform
KEYCLOAK_CLIENT_ID=web
KEYCLOAK_CLIENT_SECRET=change-me-keycloak-secret

# ─── Auth.js ─────────────────────────────────────────────────────────────────
AUTH_SECRET=change-me-32-char-min-auth-secret!!
AUTH_URL=https://app.lvh.me

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Email ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@example.com

# ─── Observability ───────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=saas-platform-web

# ─── Internal ────────────────────────────────────────────────────────────────
PLATFORM_INTERNAL_SECRET=change-me-internal-secret

# ─── Keycloak admin (local only) ─────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
